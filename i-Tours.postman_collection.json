              "raw": "{\n  \"destinationId\": 1,\n  \"tripType\": \"family\",\n  \"numberOfPersons\": 4,\n  \"stayDuration\": \"3 days\",\n  \"startDate\": \"2025-12-20\",\n  \"endDate\": \"2025-12-23\",\n  \"userId\": 1\n}"
